-- Calculates attributes and rarity for a single square
function AttributesModule.calculateSquare(luck)

	local activations = {}

	for attributeName, rarityValue in pairs(DefaultList) do
		if math.random() < 1 - (1 - 1 / rarityValue) ^ luck then
			activations[attributeName] = rarityValue
		end
	end
	
	local square_Rarity = 1
	
	local rarities = {1}
	local names = {}
	
	for attributeName, value in activations do
		
		-- rarityValue
		square_Rarity *= value
		
		table.insert(rarities, value)
		table.insert(names, attributeName)
	end
	
	local square_RarestAttributeValue = math.max(unpack(rarities))
	
	local square_String = table.concat(names, ", ")
	if square_RarestAttributeValue == 1 then
		square_String = "Normal"
	end
	local square_AttributeCount = #activations
	
	return square_Rarity, square_RarestAttributeValue, square_AttributeCount, square_String
end

return AttributesModule
